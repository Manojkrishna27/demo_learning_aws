# ──────────────────────────────────────────────────────────────
# Elastic Beanstalk – Python platform configuration
# File: .ebextensions/01_flask.config
# ──────────────────────────────────────────────────────────────

option_settings:

  # ── Python platform settings ────────────────────────────────
  aws:elasticbeanstalk:container:python:
    WSGIPath: backend/wsgi:app

  # ── Environment variables (set real values in EB console!) ──
  aws:elasticbeanstalk:application:environment:
    FLASK_ENV:    production
    PYTHONPATH:   /var/app/current
    PORT:         "8000"

  # ── HTTPS redirect (if using EB load balancer listener) ─────
  aws:elb:listener:443:
    ListenerProtocol:      HTTPS
    InstancePort:          "80"
    InstanceProtocol:      HTTP

  # ── Auto-scaling ────────────────────────────────────────────
  aws:autoscaling:asg:
    MinSize: "1"
    MaxSize: "3"

  # ── Instance type ────────────────────────────────────────────
  aws:autoscaling:launchconfiguration:
    InstanceType: t3.micro    # free tier eligible

  # ── Load balancer health check ───────────────────────────────
  aws:elasticbeanstalk:environment:process:default:
    HealthCheckPath: /api/health
    MatcherHTTPCode: "200"

packages:
  yum:
    postgresql-devel: []    # needed by psycopg2

container_commands:
  01_upgrade_pip:
    command: "pip install --upgrade pip"
  02_install_requirements:
    command: "pip install -r backend/requirements.txt"
  03_db_migrate:
    command: "cd /var/app/current && flask --app backend.app:create_app db upgrade"
    leader_only: true
    env:
      FLASK_ENV: production
