# Development overrides – never commit to git
FLASK_ENV=development
SECRET_KEY=dev-super-secret-key-change-me

# SQLite (default for dev)
# DATABASE_URL=sqlite:///calcpro_dev.db

# PostgreSQL (uncomment for Postgres)
# DATABASE_URL=postgresql://calcpro_user:password@localhost:5432/calcpro_db

# Production CORS whitelist (comma-separated)
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

HOST=0.0.0.0
PORT=5000
